  "method_hypotheses": [
    {
      "expected_mechanism": "显式版本、来源和依赖关系使事件影响能够沿受影响子图传播，并在候选继续使用前标记失效对象。",
      "hypothesis_id": "MH-1",
      "method_ids": [
        "M-1",
        "M-2"
      ],
      "rq_ids": [
        "RQ-1"
      ],
      "statement": "统一对象关系模型与增量影响传播能够减少多智能体并行运行中的状态不一致、过期依据使用和不必要的全量重算。",
      "status": "PROPOSED_METHOD_HYPOTHESIS",
      "test_design": "比较无统一状态、全量同步和增量传播三种设置下的一致性错误、重算范围、传播时延和追溯覆盖。"
    },
    {
      "expected_mechanism": "生成与批判角色独立减少自我确认，规则工具和求解器在候选入集前排除不可行解，责任定位支持局部修复。",
      "hypothesis_id": "MH-2",
      "method_ids": [
        "M-3",
        "M-4"
      ],
      "rq_ids": [
        "RQ-1",
        "RQ-2"
      ],
      "statement": "角色分离的多智能体候选竞争与确定性工具校验能够在保持硬约束可行的同时提高候选多样性和局部修复效率。",
      "status": "PROPOSED_METHOD_HYPOTHESIS",
      "test_design": "比较单Agent、无独立Critic、无确定性工具和完整机制的候选多样性、首个可行解时间、违规数和修复成本。"
    },
    {
      "expected_mechanism": "调度器把资源优先分配给预期单位时间价值较高且能关闭关键风险或证据缺口的动作，并在收益不足时停止。",
      "hypothesis_id": "MH-3",
      "method_ids": [
        "M-4",
        "M-6"
      ],
      "rq_ids": [
        "RQ-2"
      ],
      "statement": "依据边际增益、剩余时间、风险和证据状态进行自适应动作选择，能够在相同资源预算下优于固定轮次或固定角色顺序。",
      "status": "PROPOSED_METHOD_HYPOTHESIS",
      "test_design": "在多个时间和算力预算下比较固定轮次、贪心质量改进、仅按风险调度和完整调度的质量时间曲线与按时完成率。"
    },
    {
      "expected_mechanism": "候选差异和不确定性估计将人工注意力集中到机器难以可靠裁定且潜在收益较高的问题，回答被转化为有范围的偏好约束。",
      "hypothesis_id": "MH-4",
      "method_ids": [
        "M-5",
        "M-6",
        "M-7"
      ],
      "rq_ids": [
        "RQ-2",
        "RQ-3"
      ],
      "statement": "只在高价值分歧点发起人工交互并记录权限范围，能够在保持最终人工控制的同时降低人工负担并提高方案理解与采纳表现。",
      "status": "PROPOSED_METHOD_HYPOTHESIS",
      "test_design": "比较全程人工确认、仅最终审批、固定频率提问和主动高价值提问在人工时间、操作数、覆盖次数、方案质量和采纳率上的差异。"
    }
  ],
