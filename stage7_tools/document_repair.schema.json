{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "actual_model_id",
    "endpoint_id",
    "repair_round",
    "basis_finding_codes",
    "edits",
    "citation_map",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "prompt_id": {
      "const": "P-STAGE7-TARGETED-DOCUMENT-EDIT"
    },
    "actual_model_id": {
      "type": "string",
      "minLength": 1
    },
    "endpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "repair_round": {
      "type": "integer",
      "enum": [
        1,
        2
      ]
    },
    "basis_finding_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "edits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "paragraph_id",
          "old_text_sha256",
          "new_text",
          "change_type",
          "reason"
        ],
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^SEC-[0-9]{2}$"
          },
          "paragraph_id": {
            "type": "string",
            "minLength": 1
          },
          "old_text_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "new_text": {
            "type": "string",
            "minLength": 30
          },
          "change_type": {
            "enum": [
              "IDENTIFIER_TO_PROSE",
              "CITATION_NORMALIZATION",
              "TERMINOLOGY_NORMALIZATION",
              "COMBINED"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "citation_map": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "citation_number"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^SRC-(PUB|STD)-[0-9]{2}$"
          },
          "citation_number": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "heading_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "subsection_id",
          "old_title_sha256",
          "new_title",
          "reason"
        ],
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^SEC-[0-9]{2}$"
          },
          "subsection_id": {
            "type": "string",
            "minLength": 1
          },
          "old_title_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "new_title": {
            "type": "string",
            "minLength": 4
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "visual_caption_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "visual_id",
          "old_caption_sha256",
          "new_caption",
          "reason"
        ],
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^SEC-[0-9]{2}$"
          },
          "visual_id": {
            "type": "string",
            "minLength": 1
          },
          "old_caption_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "new_caption": {
            "type": "string",
            "minLength": 4
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
