{
  "$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":false,
  "required":["schema_version","prompt_id","actual_model_id","endpoint_id","verdict","checked_section_ids","scorecard","central_proposition","argument_chains","terminology","citation_check","page_budget","redundancy","findings","unresolved_items","next_action"],
  "properties":{
    "schema_version":{"const":"1.0"},"prompt_id":{"const":"P-STAGE7-FULL-INTEGRATION-CRITIC"},
    "actual_model_id":{"type":"string","minLength":1},"endpoint_id":{"type":"string","minLength":1},
    "verdict":{"enum":["ACCEPT","REVISE","BLOCK"]},
    "checked_section_ids":{"type":"array","minItems":14,"maxItems":14,"uniqueItems":true,"items":{"type":"string","pattern":"^SEC-[0-9]{2}$"}},
    "scorecard":{"type":"array","minItems":12,"items":{"type":"object","additionalProperties":false,"required":["dimension","score","result","evidence","required_action"],"properties":{"dimension":{"enum":["DOCUMENT_TYPE_FIT","CENTRAL_THESIS","ARGUMENT_CHAIN","EVIDENCE_SUPPORT","METHOD_SUBSTANCE","INNOVATION_BASELINE","FEASIBILITY_FOUNDATION","METRIC_JUSTIFICATION","SECTION_UNIQUENESS","STYLE_AND_DENSITY","PAGE_BUDGET","CROSS_SECTION_CONSISTENCY"]},"score":{"type":"number","minimum":0,"maximum":5},"result":{"enum":["PASS","REVISE","FAIL"]},"evidence":{"type":"array","items":{"type":"string","minLength":1}},"required_action":{"type":["string","null"]}}}},
    "central_proposition":{"type":"object","additionalProperties":false,"required":["id","covered","supporting_section_ids","missing_links"],"properties":{"id":{"const":"CP-1"},"covered":{"type":"boolean"},"supporting_section_ids":{"type":"array","items":{"type":"string"}},"missing_links":{"type":"array","items":{"type":"string"}}}},
    "argument_chains":{"type":"array","minItems":6,"items":{"type":"object","additionalProperties":false,"required":["chain_type","complete","source_ids","target_ids","evidence"],"properties":{"chain_type":{"enum":["GAP_TO_QUESTION","QUESTION_TO_OBJECTIVE","OBJECTIVE_TO_WORK_PACKAGE","WORK_PACKAGE_TO_METHOD","METHOD_TO_EVALUATION","RESULT_TO_CONTRIBUTION"]},"complete":{"type":"boolean"},"source_ids":{"type":"array","items":{"type":"string"}},"target_ids":{"type":"array","items":{"type":"string"}},"evidence":{"type":"string","minLength":1}}}},
    "terminology":{"type":"object","additionalProperties":false,"required":["consistent","internal_identifier_occurrences","source_identifier_occurrences","engineering_term_occurrences","affected_section_ids"],"properties":{"consistent":{"type":"boolean"},"internal_identifier_occurrences":{"type":"integer","minimum":0},"source_identifier_occurrences":{"type":"integer","minimum":0},"engineering_term_occurrences":{"type":"integer","minimum":0},"affected_section_ids":{"type":"array","items":{"type":"string"}}}},
    "citation_check":{"type":"object","additionalProperties":false,"required":["public_source_count","visible_citation_count","complete","affected_section_ids"],"properties":{"public_source_count":{"type":"integer","minimum":0},"visible_citation_count":{"type":"integer","minimum":0},"complete":{"type":"boolean"},"affected_section_ids":{"type":"array","items":{"type":"string"}}}},
    "page_budget":{"type":"object","additionalProperties":false,"required":["target_pages","max_pages","estimated_pages","within_budget","overflow_section_ids"],"properties":{"target_pages":{"type":"number"},"max_pages":{"type":"number"},"estimated_pages":{"type":"number"},"within_budget":{"type":"boolean"},"overflow_section_ids":{"type":"array","items":{"type":"string"}}}},
    "redundancy":{"type":"object","additionalProperties":false,"required":["exact_duplicate_groups","duplicate_information_key_groups","semantic_overlap_groups","affected_section_ids"],"properties":{"exact_duplicate_groups":{"type":"integer","minimum":0},"duplicate_information_key_groups":{"type":"integer","minimum":0},"semantic_overlap_groups":{"type":"integer","minimum":0},"affected_section_ids":{"type":"array","items":{"type":"string"}}}},
    "findings":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["code","severity","category","target_section_ids","description","repair_instruction","route","blocking"],"properties":{"code":{"type":"string"},"severity":{"enum":["P0","P1","P2","P3"]},"category":{"enum":["CONTENT","INTEGRATION","FORMAT","ARGUMENT","EXPRESSION","SOURCE"]},"target_section_ids":{"type":"array","items":{"type":"string"}},"description":{"type":"string"},"repair_instruction":{"type":"string"},"route":{"enum":["WRITING_AGENT","EXPRESSION_EDITOR_AGENT","INTEGRATION_AGENT","USER","BLOCK"]},"blocking":{"type":"boolean"}}}},
    "unresolved_items":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["item_id","description","blocking","required_action"],"properties":{"item_id":{"type":"string"},"description":{"type":"string"},"blocking":{"type":"boolean"},"required_action":{"type":"string"}}}},
    "next_action":{"enum":["REQUEST_TARGETED_EXPRESSION_REPAIR","REQUEST_CONTENT_REPAIR","ALLOW_STAGE_8","BLOCK"]}
  }
}
