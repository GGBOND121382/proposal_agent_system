{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version", "stage", "project_title", "upstream_artifact",
    "source_registry", "prior_work_updates", "foundation_updates",
    "metric_justification", "gap_disposition", "open_items_remaining", "readiness"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "stage": {"const": "STAGE_4A_EVIDENCE_COMPLETION"},
    "project_title": {"type": "string", "minLength": 2},
    "upstream_artifact": {
      "type": "object",
      "required": ["stage", "sha256"],
      "additionalProperties": false,
      "properties": {
        "stage": {"const": "STAGE_4_ARGUMENT_ARCHITECTURE"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "source_registry": {
      "type": "array", "minItems": 10,
      "items": {
        "type": "object",
        "required": ["source_id", "source_type", "title", "year", "verification_status", "supports_rq_ids", "evidence_scope", "limitations", "locator"],
        "additionalProperties": false,
        "properties": {
          "source_id": {"type": "string", "pattern": "^SRC-[A-Z]+-[0-9]{2}$"},
          "source_type": {"enum": ["PEER_REVIEWED_PAPER", "OFFICIAL_STANDARD", "USER_ASSERTED", "INTERNAL_TRACE"]},
          "title": {"type": "string", "minLength": 3},
          "authors": {"type": "array", "items": {"type": "string"}},
          "year": {"type": "integer", "minimum": 2000, "maximum": 2100},
          "venue": {"type": "string"},
          "doi": {"type": "string"},
          "locator": {"type": "string", "minLength": 3},
          "verification_status": {"enum": ["VERIFIED_PUBLIC", "USER_ASSERTED_UNVERIFIED", "VERIFIED_INTERNAL_TRACE"]},
          "supports_rq_ids": {"type": "array", "items": {"enum": ["RQ-1", "RQ-2", "RQ-3"]}},
          "evidence_scope": {"type": "string", "minLength": 10},
          "limitations": {"type": "string", "minLength": 10}
        }
      }
    },
    "prior_work_updates": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["prior_node_id", "rq_id", "status", "closest_work_source_ids", "mechanism_summary", "boundary_summary", "comparison_dimensions", "innovation_boundary"],
        "additionalProperties": false,
        "properties": {
          "prior_node_id": {"enum": ["PRIOR-1", "PRIOR-2", "PRIOR-3"]},
          "rq_id": {"enum": ["RQ-1", "RQ-2", "RQ-3"]},
          "status": {"const": "SUPPORTED_PUBLIC_RESEARCH"},
          "closest_work_source_ids": {"type": "array", "minItems": 2, "items": {"type": "string"}},
          "mechanism_summary": {"type": "string", "minLength": 20},
          "boundary_summary": {"type": "string", "minLength": 20},
          "comparison_dimensions": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 4}},
          "innovation_boundary": {"type": "string", "minLength": 20}
        }
      }
    },
    "foundation_updates": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object",
        "required": ["foundation_node_id", "status", "source_ids", "capability_statement", "proof_scope", "remaining_limitations"],
        "additionalProperties": false,
        "properties": {
          "foundation_node_id": {"enum": ["FOUND-1", "FOUND-2", "FOUND-3"]},
          "status": {"enum": ["PARTIALLY_SUPPORTED_USER_ASSERTED", "SUPPORTED_INTERNAL_TRACE", "PLANNED_NOT_YET_SUPPORTED"]},
          "source_ids": {"type": "array", "items": {"type": "string"}},
          "capability_statement": {"type": "string", "minLength": 20},
          "proof_scope": {"type": "string", "minLength": 20},
          "remaining_limitations": {"type": "string", "minLength": 10}
        }
      }
    },
    "metric_justification": {
      "type": "array", "minItems": 8, "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["metric_id", "status", "measurement_protocol", "baseline_groups", "statistical_summary", "threshold_status", "source_ids"],
        "additionalProperties": false,
        "properties": {
          "metric_id": {"pattern": "^MET-[1-8]$", "type": "string"},
          "status": {"const": "PROTOCOL_FROZEN_THRESHOLD_PROVISIONAL"},
          "measurement_protocol": {"type": "string", "minLength": 20},
          "baseline_groups": {"type": "array", "minItems": 2, "items": {"type": "string"}},
          "statistical_summary": {"type": "string", "minLength": 10},
          "threshold_status": {"const": "PROVISIONAL_TARGET_NOT_EMPIRICAL_RESULT"},
          "source_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "gap_disposition": {
      "type": "array", "minItems": 5, "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["gap_id", "disposition", "content_planning_blocking", "final_submission_blocking", "rationale", "remaining_actions"],
        "additionalProperties": false,
        "properties": {
          "gap_id": {"pattern": "^EVID-GAP-0[1-5]$", "type": "string"},
          "disposition": {"enum": ["RESOLVED_FOR_CONTENT_PLANNING", "RECLASSIFIED_FINAL_COMPLIANCE", "PARTIALLY_RESOLVED_FOR_CONTENT_PLANNING"]},
          "content_planning_blocking": {"type": "boolean"},
          "final_submission_blocking": {"type": "boolean"},
          "rationale": {"type": "string", "minLength": 20},
          "remaining_actions": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "open_items_remaining": {"type": "array", "items": {"type": "string", "pattern": "^OPEN-[0-9]{3}$"}},
    "readiness": {
      "type": "object",
      "required": ["ready_for_provisional_section_planning", "ready_for_final_section_contract", "planning_mode", "mandatory_revalidation_triggers", "rationale"],
      "additionalProperties": false,
      "properties": {
        "ready_for_provisional_section_planning": {"type": "boolean"},
        "ready_for_final_section_contract": {"type": "boolean"},
        "planning_mode": {"enum": ["REVERSIBLE_CONTENT_PLAN", "HOLD"]},
        "mandatory_revalidation_triggers": {"type": "array", "minItems": 2, "items": {"type": "string"}},
        "rationale": {"type": "string", "minLength": 30}
      }
    }
  }
}
