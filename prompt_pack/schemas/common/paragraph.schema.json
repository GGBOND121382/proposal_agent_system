{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paragraph.schema.json",
  "type": "object",
  "properties": {
    "paragraph_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "paragraph_role": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "blueprint_paragraph_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "trace_link_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
      },
      "minItems": 1
    },
    "preserved_source_span": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "contains_unresolved_placeholder": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "required": [
    "paragraph_id",
    "sequence",
    "paragraph_role",
    "text",
    "blueprint_paragraph_id",
    "trace_link_ids",
    "preserved_source_span",
    "contains_unresolved_placeholder"
  ]
}
