{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "object_ref.schema.json",
  "type": "object",
  "properties": {
    "object_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "object_type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "object_hash": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "security_level": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "SENSITIVE",
        "CLASSIFIED"
      ]
    },
    "display_name": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 0
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "object_id",
    "object_type",
    "version",
    "security_level"
  ]
}
