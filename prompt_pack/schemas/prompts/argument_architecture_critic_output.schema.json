{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "argument_architecture_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-ARGUMENT-ARCHITECTURE-CRITIC"
    },
    "prompt_version": {
      "const": "3.1.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "checked_node_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          },
          "minItems": 1
        },
        "chain_checks": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "chain_type": {
                "type": "string",
                "enum": [
                  "GAP_TO_QUESTION",
                  "QUESTION_TO_OBJECTIVE",
                  "OBJECTIVE_TO_WORK_PACKAGE",
                  "WORK_PACKAGE_TO_METHOD",
                  "METHOD_TO_EVALUATION",
                  "PRIOR_WORK_TO_INNOVATION",
                  "FOUNDATION_TO_FEASIBILITY"
                ]
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "minItems": 1
              },
              "target_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "minItems": 1
              },
              "complete": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "chain_type",
              "source_ids",
              "target_ids",
              "complete",
              "evidence"
            ]
          }
        },
        "design_matrix_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "research_question_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "complete": {
                "type": "boolean"
              },
              "missing_dimensions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "research_question_id",
              "complete",
              "missing_dimensions",
              "evidence"
            ]
          }
        },
        "evidence_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "node_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "supported": {
                "type": "boolean"
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "node_id",
              "supported",
              "source_ids",
              "reason"
            ]
          }
        },
        "quality_dimensions": {
          "$ref": "../common/quality_scorecard.schema.json"
        }
      },
      "required": [
        "verdict",
        "checked_node_ids",
        "chain_checks",
        "design_matrix_checks",
        "evidence_checks",
        "quality_dimensions"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
