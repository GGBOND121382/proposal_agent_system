{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "template_extract_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-TEMPLATE-EXTRACT"
    },
    "prompt_version": {
      "const": "3.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "template": {
          "type": "object",
          "properties": {
            "template_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "global_argument": {
              "type": "string",
              "minLength": 1
            },
            "components": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "component_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "section_role": {
                    "type": "string",
                    "minLength": 1
                  },
                  "input_requirements": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "output_function": {
                    "type": "string",
                    "minLength": 1
                  },
                  "paragraph_patterns": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "forbidden_project_facts": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "additionalProperties": false,
                "required": [
                  "component_id",
                  "section_role",
                  "input_requirements",
                  "output_function",
                  "paragraph_patterns",
                  "forbidden_project_facts"
                ]
              }
            },
            "format_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "applicability": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "argument_patterns": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "pattern_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sequence": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 2
                  },
                  "applicable_profiles": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  },
                  "evidence": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "pattern_id",
                  "name",
                  "sequence",
                  "applicable_profiles",
                  "evidence"
                ]
              }
            },
            "expression_patterns": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "pattern_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "function": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "safe_example": {
                    "type": "string",
                    "minLength": 1
                  },
                  "anti_copy_rule": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "pattern_id",
                  "function",
                  "description",
                  "safe_example",
                  "anti_copy_rule"
                ]
              }
            },
            "quality_anti_patterns": {
              "type": "array",
              "minItems": 5,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "code": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "detection_hint": {
                    "type": "string",
                    "minLength": 1
                  },
                  "repair_rule": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "code",
                  "description",
                  "detection_hint",
                  "repair_rule"
                ]
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "template_id",
            "global_argument",
            "components",
            "format_rules",
            "applicability",
            "argument_patterns",
            "expression_patterns",
            "quality_anti_patterns"
          ]
        },
        "source_fact_exclusions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "component_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "section_id",
              "component_ids"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "template",
        "source_fact_exclusions",
        "coverage"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
