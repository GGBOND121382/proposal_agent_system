{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "checked_paragraph_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "unsupported_trace_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "blueprint_deviation_paragraph_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "scope_violations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "profile_acceptance_results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule": {
                "type": "string",
                "minLength": 1
              },
              "passed": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "rule",
              "passed",
              "evidence"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "verdict",
        "checked_paragraph_ids",
        "unsupported_trace_ids",
        "blueprint_deviation_paragraph_ids",
        "scope_violations",
        "profile_acceptance_results"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
