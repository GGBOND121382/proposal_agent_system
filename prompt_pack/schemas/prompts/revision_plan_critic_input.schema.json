{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "revision_plan_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-REVISION-PLAN-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "revision_plan_candidate": {
          "type": "object",
          "properties": {
            "plan_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "issue_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "evidence_refs": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "P0",
                      "P1",
                      "P2",
                      "P3"
                    ]
                  }
                },
                "additionalProperties": false,
                "required": [
                  "issue_id",
                  "description",
                  "evidence_refs",
                  "severity"
                ]
              }
            },
            "target_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "minItems": 1
            },
            "read_only_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "protected_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "revision_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "operation": {
                    "type": "string",
                    "enum": [
                      "COPY_EDIT",
                      "RESTRUCTURE",
                      "SUPPLEMENT",
                      "GENERATE_EMPTY_SECTION",
                      "DELETE_PARAGRAPH",
                      "REORDER_PARAGRAPH"
                    ]
                  },
                  "objective": {
                    "type": "string",
                    "minLength": 1
                  },
                  "issue_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    },
                    "minItems": 1
                  },
                  "required_input_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "acceptance_rules": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "revision_task_id",
                  "operation",
                  "objective",
                  "issue_ids",
                  "required_input_ids",
                  "acceptance_rules"
                ]
              },
              "minItems": 1
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "predecessor_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "successor_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "predecessor_task_id",
                  "successor_task_id"
                ]
              }
            },
            "user_question_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "plan_id",
            "issues",
            "target_section_ids",
            "read_only_section_ids",
            "protected_section_ids",
            "tasks",
            "dependencies",
            "user_question_ids"
          ]
        },
        "task_instruction": {
          "$ref": "../inputs/task_instruction.schema.json"
        },
        "scheme_profile": {
          "$ref": "../inputs/application_scheme_profile.schema.json"
        },
        "project_subgraph": {
          "type": "object",
          "properties": {
            "item_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "relation_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "../common/project_item.schema.json"
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "../common/project_relation.schema.json"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "item_ids",
            "relation_ids",
            "items",
            "relations"
          ]
        },
        "fact_context": {
          "type": "array",
          "items": {
            "$ref": "../common/claim.schema.json"
          }
        },
        "source_section": {
          "$ref": "../common/document_section.schema.json"
        },
        "section_profile": {
          "type": "object",
          "properties": {
            "profile_id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "required_inputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "acceptance_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "profile_id",
            "version",
            "required_inputs",
            "acceptance_rules"
          ]
        },
        "deterministic_findings": {
          "type": "array",
          "items": {
            "$ref": "../common/finding.schema.json"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "revision_plan_candidate",
        "task_instruction",
        "scheme_profile",
        "project_subgraph",
        "fact_context",
        "source_section",
        "section_profile",
        "deterministic_findings"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
