{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "integration_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-INTEGRATION-CRITIC"
    },
    "prompt_version": {
      "const": "3.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "terminology_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": {
                "type": "string",
                "minLength": 1
              },
              "consistent": {
                "type": "boolean"
              },
              "sections": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "term",
              "consistent",
              "sections"
            ]
          }
        },
        "numeric_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value_key": {
                "type": "string",
                "minLength": 1
              },
              "consistent": {
                "type": "boolean"
              },
              "occurrences": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "value_key",
              "consistent",
              "occurrences"
            ]
          }
        },
        "mapping_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mapping_type": {
                "type": "string",
                "enum": [
                  "OBJECTIVE_TO_WORK_PACKAGE",
                  "WORK_PACKAGE_TO_METHOD",
                  "WORK_PACKAGE_TO_DELIVERABLE",
                  "DELIVERABLE_TO_METRIC"
                ]
              },
              "source_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "target_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              },
              "complete": {
                "type": "boolean"
              }
            },
            "additionalProperties": false,
            "required": [
              "mapping_type",
              "source_id",
              "target_ids",
              "complete"
            ]
          }
        },
        "routing_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_code": {
                "type": "string",
                "minLength": 1
              },
              "route": {
                "type": "string",
                "enum": [
                  "PROJECT_KNOWLEDGE_AGENT",
                  "SECURITY_REVIEW_AGENT",
                  "PLANNING_AGENT",
                  "WRITING_AGENT",
                  "USER",
                  "BLOCK"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "finding_code",
              "route",
              "reason"
            ]
          }
        },
        "quality_dimensions": {
          "$ref": "../common/quality_scorecard.schema.json"
        },
        "central_proposition_coverage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "central_proposition_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "covered": {
              "type": "boolean"
            },
            "supporting_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "missing_links": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "central_proposition_id",
            "covered",
            "supporting_section_ids",
            "missing_links"
          ]
        },
        "document_type_drift": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "detected": {
              "type": "boolean"
            },
            "main_body_term_hits": {
              "type": "integer",
              "minimum": 0
            },
            "affected_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "terms": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "detected",
            "main_body_term_hits",
            "affected_section_ids",
            "terms"
          ]
        },
        "redundancy_report": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exact_duplicate_groups": {
              "type": "integer",
              "minimum": 0
            },
            "semantic_template_groups": {
              "type": "integer",
              "minimum": 0
            },
            "affected_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "representative_signatures": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "duplicate_information_key_groups": {
              "type": "integer",
              "minimum": 0
            },
            "claim_overconcentration_groups": {
              "type": "integer",
              "minimum": 0
            },
            "template_skeleton_groups": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "exact_duplicate_groups",
            "semantic_template_groups",
            "affected_section_ids",
            "representative_signatures",
            "duplicate_information_key_groups",
            "claim_overconcentration_groups",
            "template_skeleton_groups"
          ]
        },
        "page_budget_check": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "main_body_page_budget": {
              "type": "integer",
              "minimum": 1
            },
            "estimated_main_body_pages": {
              "type": "integer",
              "minimum": 1
            },
            "within_budget": {
              "type": "boolean"
            },
            "overflow_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            }
          },
          "required": [
            "main_body_page_budget",
            "estimated_main_body_pages",
            "within_budget",
            "overflow_section_ids"
          ]
        },
        "argument_chain_checks": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "chain_type": {
                "type": "string",
                "enum": [
                  "GAP_TO_QUESTION",
                  "QUESTION_TO_OBJECTIVE",
                  "OBJECTIVE_TO_WORK_PACKAGE",
                  "WORK_PACKAGE_TO_METHOD",
                  "METHOD_TO_EVALUATION",
                  "RESULT_TO_CONTRIBUTION"
                ]
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "minItems": 1
              },
              "target_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "minItems": 1
              },
              "complete": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "chain_type",
              "source_ids",
              "target_ids",
              "complete",
              "evidence"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "verdict",
        "terminology_checks",
        "numeric_checks",
        "mapping_checks",
        "routing_actions",
        "quality_dimensions",
        "central_proposition_coverage",
        "document_type_drift",
        "redundancy_report",
        "page_budget_check",
        "argument_chain_checks"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
