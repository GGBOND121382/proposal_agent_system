{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "integration_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-INTEGRATION-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "terminology_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": {
                "type": "string",
                "minLength": 1
              },
              "consistent": {
                "type": "boolean"
              },
              "sections": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "term",
              "consistent",
              "sections"
            ]
          }
        },
        "numeric_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value_key": {
                "type": "string",
                "minLength": 1
              },
              "consistent": {
                "type": "boolean"
              },
              "occurrences": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "value_key",
              "consistent",
              "occurrences"
            ]
          }
        },
        "mapping_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mapping_type": {
                "type": "string",
                "enum": [
                  "OBJECTIVE_TO_WORK_PACKAGE",
                  "WORK_PACKAGE_TO_METHOD",
                  "WORK_PACKAGE_TO_DELIVERABLE",
                  "DELIVERABLE_TO_METRIC"
                ]
              },
              "source_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "target_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              },
              "complete": {
                "type": "boolean"
              }
            },
            "additionalProperties": false,
            "required": [
              "mapping_type",
              "source_id",
              "target_ids",
              "complete"
            ]
          }
        },
        "routing_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_code": {
                "type": "string",
                "minLength": 1
              },
              "route": {
                "type": "string",
                "enum": [
                  "PROJECT_KNOWLEDGE_AGENT",
                  "SECURITY_REVIEW_AGENT",
                  "PLANNING_AGENT",
                  "WRITING_AGENT",
                  "USER",
                  "BLOCK"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "finding_code",
              "route",
              "reason"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "verdict",
        "terminology_checks",
        "numeric_checks",
        "mapping_checks",
        "routing_actions"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
