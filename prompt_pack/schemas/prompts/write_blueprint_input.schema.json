{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_blueprint_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-BLUEPRINT"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "confirmed_plan": {
          "type": "object",
          "properties": {
            "plan_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "issue_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "evidence_refs": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "P0",
                      "P1",
                      "P2",
                      "P3"
                    ]
                  }
                },
                "additionalProperties": false,
                "required": [
                  "issue_id",
                  "description",
                  "evidence_refs",
                  "severity"
                ]
              }
            },
            "target_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "minItems": 1
            },
            "read_only_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "protected_section_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "revision_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "operation": {
                    "type": "string",
                    "enum": [
                      "COPY_EDIT",
                      "RESTRUCTURE",
                      "SUPPLEMENT",
                      "GENERATE_EMPTY_SECTION",
                      "DELETE_PARAGRAPH",
                      "REORDER_PARAGRAPH"
                    ]
                  },
                  "objective": {
                    "type": "string",
                    "minLength": 1
                  },
                  "issue_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    },
                    "minItems": 1
                  },
                  "required_input_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "acceptance_rules": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "revision_task_id",
                  "operation",
                  "objective",
                  "issue_ids",
                  "required_input_ids",
                  "acceptance_rules"
                ]
              },
              "minItems": 1
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "predecessor_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "successor_task_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "predecessor_task_id",
                  "successor_task_id"
                ]
              }
            },
            "user_question_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "narrative_architecture": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "architecture_id": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "document_type": {
                  "type": "string",
                  "enum": [
                    "RESEARCH_PROPOSAL",
                    "ENGINEERING_PROPOSAL",
                    "HYBRID_RESEARCH_PROPOSAL"
                  ]
                },
                "central_proposition_id": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "central_proposition": {
                  "type": "string",
                  "minLength": 20
                },
                "research_question_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "minItems": 1,
                  "maxItems": 4
                },
                "closest_prior_work_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "minItems": 1
                },
                "work_package_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "minItems": 2,
                  "maxItems": 5
                },
                "main_body_page_budget": {
                  "type": "integer",
                  "minimum": 10,
                  "maximum": 80
                },
                "main_body_word_budget": {
                  "type": "integer",
                  "minimum": 5000,
                  "maximum": 60000
                },
                "section_contracts": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "../common/section_contract.schema.json"
                  }
                },
                "attachments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "attachment_id": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                      },
                      "title": {
                        "type": "string",
                        "minLength": 1
                      },
                      "purpose": {
                        "type": "string",
                        "minLength": 1
                      },
                      "content_types": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        },
                        "minItems": 1
                      }
                    },
                    "required": [
                      "attachment_id",
                      "title",
                      "purpose",
                      "content_types"
                    ]
                  }
                }
              },
              "required": [
                "architecture_id",
                "document_type",
                "central_proposition_id",
                "central_proposition",
                "research_question_ids",
                "closest_prior_work_ids",
                "work_package_ids",
                "main_body_page_budget",
                "main_body_word_budget",
                "section_contracts",
                "attachments"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "plan_id",
            "issues",
            "target_section_ids",
            "read_only_section_ids",
            "protected_section_ids",
            "tasks",
            "dependencies",
            "user_question_ids",
            "narrative_architecture"
          ]
        },
        "section_profile": {
          "type": "object",
          "properties": {
            "profile_id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "required_inputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "acceptance_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "profile_id",
            "version",
            "required_inputs",
            "acceptance_rules"
          ]
        },
        "template_context": {
          "type": "object",
          "properties": {
            "template_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "component_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "template_id",
            "component_ids",
            "rules"
          ]
        },
        "project_subgraph": {
          "type": "object",
          "properties": {
            "item_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "relation_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "../common/project_item.schema.json"
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "../common/project_relation.schema.json"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "item_ids",
            "relation_ids",
            "items",
            "relations"
          ]
        },
        "confirmed_facts": {
          "type": "array",
          "items": {
            "$ref": "../common/claim.schema.json"
          }
        },
        "technical_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "metric_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "source_section": {
          "$ref": "../common/document_section.schema.json"
        },
        "security_constraints": {
          "$ref": "../common/security_context.schema.json"
        },
        "proposal_contract": {
          "$ref": "../common/proposal_contract.schema.json"
        },
        "argument_graph": {
          "$ref": "../common/argument_graph.schema.json"
        },
        "narrative_architecture": {
          "type": "object",
          "minProperties": 5
        },
        "section_contract": {
          "$ref": "../common/section_contract.schema.json"
        },
        "prior_section_digest": {
          "type": "array",
          "items": {
            "$ref": "../common/prior_section_digest.schema.json"
          }
        },
        "revision_findings": {
          "type": "array",
          "items": {
            "$ref": "../common/finding.schema.json"
          },
          "description": "来自上一轮全篇质量审查、且明确指向当前章节的结构化修订意见；首次生成时为空数组。"
        }
      },
      "additionalProperties": false,
      "required": [
        "confirmed_plan",
        "section_profile",
        "template_context",
        "project_subgraph",
        "confirmed_facts",
        "technical_inputs",
        "metric_inputs",
        "source_section",
        "security_constraints",
        "proposal_contract",
        "argument_graph",
        "narrative_architecture",
        "section_contract",
        "prior_section_digest",
        "revision_findings"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
