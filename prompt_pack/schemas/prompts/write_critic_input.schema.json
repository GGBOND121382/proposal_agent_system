{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "content_candidate": {
          "type": "object",
          "properties": {
            "candidate_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "candidate_text": {
              "type": "string",
              "minLength": 1
            },
            "paragraphs": {
              "type": "array",
              "items": {
                "$ref": "../common/paragraph.schema.json"
              },
              "minItems": 1
            },
            "trace_links": {
              "type": "array",
              "items": {
                "$ref": "../common/trace_link.schema.json"
              },
              "minItems": 1
            },
            "term_usage": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "term": {
                    "type": "string",
                    "minLength": 1
                  },
                  "canonical_term": {
                    "type": "string",
                    "minLength": 1
                  },
                  "paragraph_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    },
                    "minItems": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "term",
                  "canonical_term",
                  "paragraph_ids"
                ]
              }
            },
            "unresolved_items": {
              "type": "array",
              "items": {
                "$ref": "../common/unresolved_item.schema.json"
              }
            },
            "source_preservation_summary": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "source_span": {
                    "type": "string",
                    "minLength": 1
                  },
                  "action": {
                    "type": "string",
                    "enum": [
                      "PRESERVED",
                      "REPHRASED",
                      "REPLACED",
                      "REMOVED"
                    ]
                  },
                  "paragraph_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "source_span",
                  "action",
                  "paragraph_id"
                ]
              }
            },
            "claim_advancement": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "section_contract_id": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "advanced_claim_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "minItems": 1
                },
                "new_information_keys": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 8
                  },
                  "minItems": 1
                },
                "distinguished_from_section_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  }
                },
                "section_contribution": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "section_contract_id",
                "advanced_claim_ids",
                "new_information_keys",
                "distinguished_from_section_ids",
                "section_contribution"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "candidate_id",
            "candidate_text",
            "paragraphs",
            "trace_links",
            "term_usage",
            "unresolved_items",
            "source_preservation_summary",
            "claim_advancement"
          ]
        },
        "approved_blueprint": {
          "type": "object",
          "properties": {
            "blueprint_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "section_objective": {
              "type": "string",
              "minLength": 1
            },
            "paragraphs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "paragraph_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "sequence": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "function": {
                    "type": "string",
                    "minLength": 1
                  },
                  "must_answer": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "fact_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "project_item_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "technical_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "metric_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "source_strategy": {
                    "type": "string",
                    "enum": [
                      "PRESERVE",
                      "REPLACE",
                      "INSERT",
                      "MERGE"
                    ]
                  },
                  "forbidden_content": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "transition_requirement": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 0
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "argument_role": {
                    "$ref": "../common/argument_role.schema.json"
                  },
                  "primary_claim_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "required_evidence_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "novel_content_key": {
                    "type": "string",
                    "minLength": 8
                  },
                  "word_budget": {
                    "type": "integer",
                    "minimum": 40,
                    "maximum": 2000
                  }
                },
                "additionalProperties": false,
                "required": [
                  "paragraph_id",
                  "sequence",
                  "function",
                  "must_answer",
                  "fact_slots",
                  "project_item_slots",
                  "technical_slots",
                  "metric_slots",
                  "source_strategy",
                  "forbidden_content",
                  "transition_requirement",
                  "argument_role",
                  "primary_claim_id",
                  "required_evidence_ids",
                  "novel_content_key",
                  "word_budget"
                ]
              },
              "minItems": 1
            },
            "unresolved_slot_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "section_profile_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "section_contract_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          },
          "additionalProperties": false,
          "required": [
            "blueprint_id",
            "section_objective",
            "paragraphs",
            "unresolved_slot_ids",
            "section_profile_id",
            "section_contract_id"
          ]
        },
        "source_section": {
          "$ref": "../common/document_section.schema.json"
        },
        "project_subgraph": {
          "type": "object",
          "properties": {
            "item_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "relation_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "../common/project_item.schema.json"
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "../common/project_relation.schema.json"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "item_ids",
            "relation_ids",
            "items",
            "relations"
          ]
        },
        "confirmed_facts": {
          "type": "array",
          "items": {
            "$ref": "../common/claim.schema.json"
          }
        },
        "technical_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "metric_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "section_profile": {
          "type": "object",
          "properties": {
            "profile_id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "required_inputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "acceptance_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "profile_id",
            "version",
            "required_inputs",
            "acceptance_rules"
          ]
        },
        "task_instruction": {
          "$ref": "../inputs/task_instruction.schema.json"
        },
        "security_constraints": {
          "$ref": "../common/security_context.schema.json"
        },
        "proposal_contract": {
          "$ref": "../common/proposal_contract.schema.json"
        },
        "argument_graph": {
          "$ref": "../common/argument_graph.schema.json"
        },
        "narrative_architecture": {
          "type": "object",
          "minProperties": 5
        },
        "section_contract": {
          "$ref": "../common/section_contract.schema.json"
        },
        "prior_section_digest": {
          "type": "array",
          "items": {
            "$ref": "../common/prior_section_digest.schema.json"
          },
          "description": "已完成章节的结构化语义推进摘要，用于跨章节唯一性检查。"
        }
      },
      "additionalProperties": false,
      "required": [
        "content_candidate",
        "approved_blueprint",
        "source_section",
        "project_subgraph",
        "confirmed_facts",
        "technical_inputs",
        "metric_inputs",
        "section_profile",
        "task_instruction",
        "security_constraints",
        "proposal_contract",
        "argument_graph",
        "narrative_architecture",
        "section_contract",
        "prior_section_digest"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
