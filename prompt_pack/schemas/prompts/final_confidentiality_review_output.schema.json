{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "final_confidentiality_review_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-FINAL-CONFIDENTIALITY-REVIEW"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "review_outcome": {
          "type": "string",
          "enum": [
            "READY_FOR_HUMAN_REVIEW",
            "REDACTION_REQUIRED",
            "BLOCK"
          ]
        },
        "sensitive_spans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "span": {
                "type": "string",
                "minLength": 1
              },
              "risk_type": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "section_id",
              "span",
              "risk_type",
              "reason"
            ]
          }
        },
        "combination_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_redactions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recipient_fit": {
          "type": "string",
          "enum": [
            "FIT",
            "CONDITIONAL",
            "NOT_FIT"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "review_outcome",
        "sensitive_spans",
        "combination_risks",
        "required_redactions",
        "recipient_fit"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
