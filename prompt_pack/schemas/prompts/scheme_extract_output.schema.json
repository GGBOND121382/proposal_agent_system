{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scheme_extract_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SCHEME-EXTRACT"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "scheme_profile": {
          "$ref": "../inputs/application_scheme_profile.schema.json"
        },
        "extraction_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "covered_rule_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "source_id",
              "covered_rule_ids"
            ]
          }
        },
        "ambiguous_rule_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "scheme_profile",
        "extraction_coverage",
        "ambiguous_rule_ids"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
