{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "security_classify_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SECURITY-CLASSIFY"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "object_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "recommended_level": {
          "type": "string",
          "enum": [
            "PUBLIC",
            "INTERNAL",
            "SENSITIVE",
            "CLASSIFIED"
          ]
        },
        "sensitive_entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity_type": {
                "type": "string",
                "minLength": 1
              },
              "value_or_placeholder": {
                "type": "string",
                "minLength": 1
              },
              "span": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 0
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "risk": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "entity_type",
              "value_or_placeholder",
              "span",
              "risk"
            ]
          }
        },
        "sensitive_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "combination_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_environments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "OFFLINE_LOCAL",
              "ONLINE_PUBLIC"
            ]
          }
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "object_id",
        "recommended_level",
        "sensitive_entities",
        "sensitive_fields",
        "combination_risks",
        "allowed_environments",
        "rationale",
        "confidence"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
