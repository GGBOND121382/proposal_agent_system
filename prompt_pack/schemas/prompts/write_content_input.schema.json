{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_content_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-CONTENT"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "approved_blueprint": {
          "type": "object",
          "properties": {
            "blueprint_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "section_objective": {
              "type": "string",
              "minLength": 1
            },
            "paragraphs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "paragraph_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "sequence": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "function": {
                    "type": "string",
                    "minLength": 1
                  },
                  "must_answer": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "fact_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "project_item_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "technical_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "metric_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "source_strategy": {
                    "type": "string",
                    "enum": [
                      "PRESERVE",
                      "REPLACE",
                      "INSERT",
                      "MERGE"
                    ]
                  },
                  "forbidden_content": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "transition_requirement": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 0
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "argument_role": {
                    "type": "string",
                    "enum": [
                      "CONTEXT",
                      "PROBLEM",
                      "EVIDENCE",
                      "GAP",
                      "LIMITATION_MECHANISM",
                      "CENTRAL_CLAIM",
                      "RESEARCH_QUESTION",
                      "METHOD",
                      "WARRANT",
                      "COUNTERARGUMENT",
                      "BOUNDARY",
                      "EVALUATION",
                      "CONTRIBUTION",
                      "TRANSITION"
                    ]
                  },
                  "primary_claim_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "required_evidence_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "novel_content_key": {
                    "type": "string",
                    "minLength": 8
                  },
                  "word_budget": {
                    "type": "integer",
                    "minimum": 40,
                    "maximum": 2000
                  }
                },
                "additionalProperties": false,
                "required": [
                  "paragraph_id",
                  "sequence",
                  "function",
                  "must_answer",
                  "fact_slots",
                  "project_item_slots",
                  "technical_slots",
                  "metric_slots",
                  "source_strategy",
                  "forbidden_content",
                  "transition_requirement",
                  "argument_role",
                  "primary_claim_id",
                  "required_evidence_ids",
                  "novel_content_key",
                  "word_budget"
                ]
              },
              "minItems": 1
            },
            "unresolved_slot_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "section_profile_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "section_contract_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          },
          "additionalProperties": false,
          "required": [
            "blueprint_id",
            "section_objective",
            "paragraphs",
            "unresolved_slot_ids",
            "section_profile_id",
            "section_contract_id"
          ]
        },
        "source_section": {
          "$ref": "../common/document_section.schema.json"
        },
        "project_subgraph": {
          "type": "object",
          "properties": {
            "item_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "relation_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "../common/project_item.schema.json"
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "../common/project_relation.schema.json"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "item_ids",
            "relation_ids",
            "items",
            "relations"
          ]
        },
        "confirmed_facts": {
          "type": "array",
          "items": {
            "$ref": "../common/claim.schema.json"
          }
        },
        "technical_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "metric_inputs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          }
        },
        "read_only_context": {
          "type": "array",
          "items": {
            "$ref": "../common/document_section.schema.json"
          }
        },
        "template_context": {
          "type": "object",
          "properties": {
            "template_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "component_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "template_id",
            "component_ids",
            "rules"
          ]
        },
        "section_profile": {
          "type": "object",
          "properties": {
            "profile_id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "required_inputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "acceptance_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "profile_id",
            "version",
            "required_inputs",
            "acceptance_rules"
          ]
        },
        "security_constraints": {
          "$ref": "../common/security_context.schema.json"
        },
        "proposal_contract": {
          "$ref": "../common/proposal_contract.schema.json"
        },
        "argument_graph": {
          "$ref": "../common/argument_graph.schema.json"
        },
        "narrative_architecture": {
          "type": "object",
          "minProperties": 5
        },
        "section_contract": {
          "$ref": "../common/section_contract.schema.json"
        },
        "prior_section_digest": {
          "type": "array",
          "items": {
            "$ref": "../common/prior_section_digest.schema.json"
          }
        },
        "revision_findings": {
          "type": "array",
          "items": {
            "$ref": "../common/finding.schema.json"
          },
          "description": "来自上一轮全篇质量审查、且明确指向当前章节的结构化修订意见；首次生成时为空数组。"
        }
      },
      "additionalProperties": false,
      "required": [
        "approved_blueprint",
        "source_section",
        "project_subgraph",
        "confirmed_facts",
        "technical_inputs",
        "metric_inputs",
        "read_only_context",
        "template_context",
        "section_profile",
        "security_constraints",
        "proposal_contract",
        "argument_graph",
        "narrative_architecture",
        "section_contract",
        "prior_section_digest",
        "revision_findings"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
