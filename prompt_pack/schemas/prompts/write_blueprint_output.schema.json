{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_blueprint_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-BLUEPRINT"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "blueprint": {
          "type": "object",
          "properties": {
            "blueprint_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "section_objective": {
              "type": "string",
              "minLength": 1
            },
            "paragraphs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "paragraph_id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                  },
                  "sequence": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "function": {
                    "type": "string",
                    "minLength": 1
                  },
                  "must_answer": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "fact_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "project_item_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "technical_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "metric_slots": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    }
                  },
                  "source_strategy": {
                    "type": "string",
                    "enum": [
                      "PRESERVE",
                      "REPLACE",
                      "INSERT",
                      "MERGE"
                    ]
                  },
                  "forbidden_content": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "transition_requirement": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 0
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "additionalProperties": false,
                "required": [
                  "paragraph_id",
                  "sequence",
                  "function",
                  "must_answer",
                  "fact_slots",
                  "project_item_slots",
                  "technical_slots",
                  "metric_slots",
                  "source_strategy",
                  "forbidden_content",
                  "transition_requirement"
                ]
              },
              "minItems": 1
            },
            "unresolved_slot_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "blueprint_id",
            "section_objective",
            "paragraphs",
            "unresolved_slot_ids"
          ]
        },
        "plan_task_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "revision_task_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "paragraph_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                },
                "minItems": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "revision_task_id",
              "paragraph_ids"
            ]
          }
        },
        "input_usage_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "used_in_paragraph_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "source_id",
              "used_in_paragraph_ids"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "blueprint",
        "plan_task_coverage",
        "input_usage_summary"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
