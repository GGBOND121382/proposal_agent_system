{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "targeted_repair_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-TARGETED-REPAIR"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "original_object": {
          "type": "object",
          "properties": {
            "object_type": {
              "type": "string",
              "minLength": 1
            },
            "object_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "object_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            },
            "content": {
              "type": "object"
            }
          },
          "additionalProperties": false,
          "required": [
            "object_type",
            "object_id",
            "object_hash",
            "content"
          ]
        },
        "original_producer": {
          "type": "string",
          "enum": [
            "SECURITY_REVIEW_AGENT",
            "PROJECT_KNOWLEDGE_AGENT",
            "TEMPLATE_AGENT",
            "PLANNING_AGENT",
            "WRITING_AGENT"
          ]
        },
        "findings_to_repair": {
          "type": "array",
          "items": {
            "$ref": "../common/finding.schema.json"
          },
          "minItems": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "protected_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protected_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "hash": {
                "type": "string",
                "minLength": 64,
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false,
            "required": [
              "path",
              "hash"
            ]
          }
        },
        "original_input_refs": {
          "type": "array",
          "items": {
            "$ref": "../common/object_ref.schema.json"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "original_object",
        "original_producer",
        "findings_to_repair",
        "allowed_paths",
        "protected_paths",
        "protected_hashes",
        "original_input_refs"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
