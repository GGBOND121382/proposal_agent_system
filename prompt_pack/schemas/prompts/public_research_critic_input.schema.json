{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public_research_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-PUBLIC-RESEARCH-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "research_plan": {
          "type": "object",
          "properties": {
            "plan_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "task_type": {
              "type": "string",
              "enum": [
                "PUBLIC_RESEARCH",
                "PUBLIC_TEMPLATE_ANALYSIS",
                "GENERIC_LANGUAGE_ASSIST"
              ]
            },
            "research_questions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "queries": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "source_priorities": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "time_scope": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "evidence_requirements": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "prohibited_inferences": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "plan_id",
            "task_type",
            "research_questions",
            "queries",
            "source_priorities",
            "time_scope",
            "evidence_requirements",
            "prohibited_inferences"
          ]
        },
        "synthesis_candidate": {
          "type": "object",
          "properties": {
            "claims": {
              "type": "array",
              "items": {
                "$ref": "../common/claim.schema.json"
              }
            },
            "source_comparisons": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "topic": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                    },
                    "minItems": 2
                  },
                  "agreement": {
                    "type": "string",
                    "enum": [
                      "AGREE",
                      "PARTIAL",
                      "CONFLICT"
                    ]
                  },
                  "summary": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "topic",
                  "source_ids",
                  "agreement",
                  "summary"
                ]
              }
            },
            "conflicts": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "limitations": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "coverage_summary": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false,
          "required": [
            "claims",
            "source_comparisons",
            "conflicts",
            "limitations",
            "coverage_summary"
          ]
        },
        "retrieved_sources": {
          "type": "array",
          "items": {
            "$ref": "../common/source_ref.schema.json"
          }
        },
        "safe_online_package": {
          "$ref": "../common/object_ref.schema.json"
        }
      },
      "additionalProperties": false,
      "required": [
        "research_plan",
        "synthesis_candidate",
        "retrieved_sources",
        "safe_online_package"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
