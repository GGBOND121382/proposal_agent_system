{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scheme_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SCHEME-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "checked_rule_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "missing_rule_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "source_ref": {
                "$ref": "../common/source_ref.schema.json"
              }
            },
            "additionalProperties": false,
            "required": [
              "statement",
              "source_ref"
            ]
          }
        },
        "numeric_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "value_correct": {
                "type": "boolean"
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "rule_id",
              "value_correct",
              "note"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "verdict",
        "checked_rule_ids",
        "missing_rule_candidates",
        "numeric_checks"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
