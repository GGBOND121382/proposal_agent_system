{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "safe_online_package_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SAFE-ONLINE-PACKAGE"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "package_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "task_type": {
          "type": "string",
          "enum": [
            "PUBLIC_RESEARCH",
            "PUBLIC_TEMPLATE_ANALYSIS",
            "GENERIC_LANGUAGE_ASSIST"
          ]
        },
        "task_description": {
          "type": "string",
          "minLength": 1
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "allowed_context": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entity_placeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string",
                "minLength": 1
              },
              "entity_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false,
            "required": [
              "placeholder",
              "entity_type"
            ]
          }
        },
        "removed_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prohibited_inferences": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prohibited_outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "valid_until": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "security_level": {
          "const": "PUBLIC"
        }
      },
      "additionalProperties": false,
      "required": [
        "package_id",
        "task_type",
        "task_description",
        "queries",
        "allowed_context",
        "entity_placeholders",
        "removed_fields",
        "prohibited_inferences",
        "prohibited_outputs",
        "valid_until",
        "security_level"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
