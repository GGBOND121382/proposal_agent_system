{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public_research_plan_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-PUBLIC-RESEARCH-PLAN"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "safe_online_package": {
          "$ref": "../common/object_ref.schema.json"
        },
        "task_type": {
          "type": "string",
          "enum": [
            "PUBLIC_RESEARCH",
            "PUBLIC_TEMPLATE_ANALYSIS",
            "GENERIC_LANGUAGE_ASSIST"
          ]
        },
        "known_public_sources": {
          "type": "array",
          "items": {
            "$ref": "../common/source_ref.schema.json"
          }
        },
        "time_constraints": {
          "type": "object",
          "properties": {
            "start_date": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "end_date": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "freshness_required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "start_date",
            "end_date",
            "freshness_required"
          ]
        },
        "evidence_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "safe_online_package_content": {
          "type": "object",
          "properties": {
            "package_id": {
              "type": "string",
              "minLength": 1
            },
            "task_type": {
              "type": "string",
              "enum": [
                "PUBLIC_RESEARCH",
                "PUBLIC_TEMPLATE_ANALYSIS",
                "GENERIC_LANGUAGE_ASSIST"
              ]
            },
            "task_description": {
              "type": "string",
              "minLength": 1
            },
            "queries": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "allowed_context": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "prohibited_inferences": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "prohibited_outputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "security_level": {
              "const": "PUBLIC"
            }
          },
          "additionalProperties": false,
          "required": [
            "package_id",
            "task_type",
            "task_description",
            "queries",
            "allowed_context",
            "prohibited_inferences",
            "prohibited_outputs",
            "security_level"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "safe_online_package",
        "task_type",
        "known_public_sources",
        "time_constraints",
        "evidence_requirements"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
