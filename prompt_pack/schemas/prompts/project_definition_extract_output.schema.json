{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_definition_extract_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-PROJECT-DEFINITION-EXTRACT"
    },
    "prompt_version": {
      "const": "3.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "project_definition": {
          "$ref": "../inputs/project_definition_package.schema.json"
        },
        "extraction_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain": {
                "type": "string",
                "enum": [
                  "PROJECT_BASIC",
                  "BACKGROUND_AND_DEMAND",
                  "STATE_GAP_ROOT_CAUSE",
                  "CORE_PROBLEMS",
                  "OBJECTIVES",
                  "RESEARCH_CONTENT",
                  "TECHNICAL_ROUTE",
                  "INNOVATION",
                  "OUTPUTS_AND_METRICS",
                  "RESEARCH_FOUNDATION",
                  "TEAM_AND_IMPLEMENTATION",
                  "RESOURCES_BUDGET_RISK_COMPLIANCE"
                ]
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              },
              "item_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "domain",
              "source_ids",
              "item_ids"
            ]
          }
        },
        "unmapped_source_spans": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proposal_contract": {
          "$ref": "../common/proposal_contract.schema.json"
        },
        "argument_graph_seed": {
          "$ref": "../common/argument_graph.schema.json"
        }
      },
      "additionalProperties": false,
      "required": [
        "project_definition",
        "extraction_coverage",
        "unmapped_source_spans",
        "proposal_contract",
        "argument_graph_seed"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
