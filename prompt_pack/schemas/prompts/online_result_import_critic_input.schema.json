{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "online_result_import_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-ONLINE-RESULT-IMPORT-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "approved_safe_package": {
          "$ref": "../common/object_ref.schema.json"
        },
        "result_package": {
          "type": "object",
          "properties": {
            "package_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "request_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            },
            "claims": {
              "type": "array",
              "items": {
                "$ref": "../common/claim.schema.json"
              }
            },
            "raw_text": {
              "type": "string",
              "minLength": 0
            },
            "source_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              }
            },
            "manifest_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false,
          "required": [
            "package_id",
            "request_hash",
            "claims",
            "raw_text",
            "source_ids",
            "manifest_hash"
          ]
        },
        "public_sources": {
          "type": "array",
          "items": {
            "$ref": "../common/source_ref.schema.json"
          }
        },
        "transfer_manifest": {
          "type": "object",
          "properties": {
            "package_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "request_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            },
            "content_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            },
            "approved_by": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "approved_at": {
              "type": "string",
              "minLength": 1
            },
            "expires_at": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 0
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "package_id",
            "request_hash",
            "content_hash",
            "approved_by",
            "approved_at",
            "expires_at"
          ]
        },
        "security_policy": {
          "$ref": "../inputs/security_handling_profile.schema.json"
        }
      },
      "additionalProperties": false,
      "required": [
        "approved_safe_package",
        "result_package",
        "public_sources",
        "transfer_manifest",
        "security_policy"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
