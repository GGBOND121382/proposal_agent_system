{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "write_blueprint_critic_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-WRITE-BLUEPRINT-CRITIC"
    },
    "prompt_version": {
      "const": "3.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REVISE",
            "BLOCK"
          ]
        },
        "checked_paragraph_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "uncovered_revision_task_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "invalid_slot_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "critical_unresolved_slot_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "argument_checks": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "SECTION_FUNCTION",
                  "CLAIM_ADVANCEMENT",
                  "EVIDENCE_BINDING",
                  "PARAGRAPH_ROLE_DIVERSITY",
                  "NOVEL_CONTENT_KEYS",
                  "WORD_BUDGET",
                  "NO_GENERIC_SIX_PART_TEMPLATE"
                ]
              },
              "passed": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "blocking_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
                }
              }
            },
            "required": [
              "dimension",
              "passed",
              "evidence",
              "blocking_ids"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "verdict",
        "checked_paragraph_ids",
        "uncovered_revision_task_ids",
        "invalid_slot_refs",
        "critical_unresolved_slot_ids",
        "argument_checks"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
