{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "safe_online_package_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SAFE-ONLINE-PACKAGE-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "package_candidate": {
          "type": "object",
          "properties": {
            "package_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "task_type": {
              "type": "string",
              "enum": [
                "PUBLIC_RESEARCH",
                "PUBLIC_TEMPLATE_ANALYSIS",
                "GENERIC_LANGUAGE_ASSIST"
              ]
            },
            "task_description": {
              "type": "string",
              "minLength": 1
            },
            "queries": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "allowed_context": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "entity_placeholders": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "placeholder": {
                    "type": "string",
                    "minLength": 1
                  },
                  "original_type": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "placeholder",
                  "original_type"
                ]
              }
            },
            "prohibited_inferences": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "prohibited_outputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "security_level": {
              "const": "PUBLIC"
            }
          },
          "additionalProperties": false,
          "required": [
            "package_id",
            "task_type",
            "task_description",
            "queries",
            "allowed_context",
            "entity_placeholders",
            "prohibited_inferences",
            "prohibited_outputs",
            "security_level"
          ]
        },
        "source_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_item_id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
              },
              "abstracted_summary": {
                "type": "string",
                "minLength": 1
              },
              "original_security_level": {
                "type": "string",
                "enum": [
                  "PUBLIC",
                  "INTERNAL",
                  "SENSITIVE",
                  "CLASSIFIED"
                ]
              }
            },
            "additionalProperties": false,
            "required": [
              "source_item_id",
              "abstracted_summary",
              "original_security_level"
            ]
          }
        },
        "security_policy": {
          "$ref": "../inputs/security_handling_profile.schema.json"
        },
        "deterministic_scan": {
          "type": "object",
          "properties": {
            "passed": {
              "type": "boolean"
            },
            "matched_rules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "redacted_fields": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "passed",
            "matched_rules",
            "redacted_fields"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "package_candidate",
        "source_summary",
        "security_policy",
        "deterministic_scan"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
