{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "security_classify_critic_input.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-SECURITY-CLASSIFY-CRITIC"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "PROJECT_INTAKE",
            "TEMPLATE_EXTRACTION",
            "HYBRID_ONLINE_ASSIST",
            "PROPOSAL_AUTHORING",
            "SECURITY_REVIEW_AND_EXPORT"
          ]
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "writing_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "COPY_EDIT_ONLY",
                "SUBSTANTIVE_REVISION",
                "DRAFT_FROM_PROJECT_DEFINITION"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_id",
        "workflow_type",
        "current_step",
        "attempt",
        "writing_mode"
      ]
    },
    "security_context": {
      "$ref": "../common/security_context.schema.json"
    },
    "scope": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "target_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "read_only_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "protected_object_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "project_id",
        "target_object_ids",
        "read_only_object_ids",
        "protected_object_ids"
      ]
    },
    "freshness": {
      "$ref": "../common/freshness.schema.json"
    },
    "payload": {
      "type": "object",
      "properties": {
        "classification_candidate": {
          "type": "object",
          "properties": {
            "object_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "recommended_level": {
              "type": "string",
              "enum": [
                "PUBLIC",
                "INTERNAL",
                "SENSITIVE",
                "CLASSIFIED"
              ]
            },
            "sensitive_entities": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "entity_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "value_or_placeholder": {
                    "type": "string",
                    "minLength": 1
                  },
                  "span": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 0
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "risk": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false,
                "required": [
                  "entity_type",
                  "value_or_placeholder",
                  "span",
                  "risk"
                ]
              }
            },
            "sensitive_fields": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "combination_risks": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "allowed_environments": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "OFFLINE_LOCAL",
                  "ONLINE_PUBLIC"
                ]
              }
            },
            "rationale": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "confidence": {
              "type": "string",
              "enum": [
                "HIGH",
                "MEDIUM",
                "LOW"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "object_id",
            "recommended_level",
            "sensitive_entities",
            "sensitive_fields",
            "combination_risks",
            "allowed_environments",
            "rationale",
            "confidence"
          ]
        },
        "original_object": {
          "type": "object",
          "properties": {
            "object_type": {
              "type": "string",
              "minLength": 1
            },
            "object_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "object_hash": {
              "type": "string",
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$"
            },
            "content": {
              "type": "object"
            }
          },
          "additionalProperties": false,
          "required": [
            "object_type",
            "object_id",
            "object_hash",
            "content"
          ]
        },
        "security_policy": {
          "$ref": "../inputs/security_handling_profile.schema.json"
        },
        "deterministic_findings": {
          "type": "array",
          "items": {
            "$ref": "../common/finding.schema.json"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "classification_candidate",
        "original_object",
        "security_policy",
        "deterministic_findings"
      ]
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "task",
    "security_context",
    "scope",
    "freshness",
    "payload",
    "expected_output_schema"
  ]
}
