{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "targeted_repair_output.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "prompt_id": {
      "const": "P-TARGETED-REPAIR"
    },
    "prompt_version": {
      "const": "2.0.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "NEED_USER_INPUT",
        "BLOCK"
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "repaired_object": {
          "type": "object"
        },
        "changed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "unchanged_protected_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "hash": {
                "type": "string",
                "minLength": 64,
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false,
            "required": [
              "path",
              "hash"
            ]
          }
        },
        "resolved_finding_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "unresolved_finding_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "repaired_object",
        "changed_paths",
        "unchanged_protected_hashes",
        "resolved_finding_codes",
        "unresolved_finding_codes"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "../common/finding.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "../common/unresolved_item.schema.json"
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "$ref": "../common/user_question.schema.json"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/source_ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "status",
    "result",
    "findings",
    "unresolved_items",
    "user_questions",
    "source_refs",
    "warnings"
  ]
}
