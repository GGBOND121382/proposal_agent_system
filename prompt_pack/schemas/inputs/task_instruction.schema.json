{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_instruction.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "task_instruction_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "COPY_EDIT_ONLY",
        "SUBSTANTIVE_REVISION",
        "DRAFT_FROM_PROJECT_DEFINITION",
        "PUBLIC_RESEARCH",
        "PUBLIC_TEMPLATE_ANALYSIS",
        "GENERIC_LANGUAGE_ASSIST"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "target_section_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
      }
    },
    "specific_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_preserve": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_preferences": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "instruction_hash": {
      "type": "string",
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_instruction_id",
    "task_type",
    "objective",
    "target_section_ids",
    "specific_requirements",
    "must_preserve",
    "forbidden_changes",
    "acceptance_preferences",
    "priority_order",
    "instruction_hash"
  ]
}
