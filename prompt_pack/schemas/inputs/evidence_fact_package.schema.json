{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_fact_package.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "../common/claim.schema.json"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "conflict_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "minItems": 2
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "OPEN",
              "RESOLVED",
              "SUPERSEDED"
            ]
          },
          "resolution": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 0
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false,
        "required": [
          "conflict_id",
          "claim_ids",
          "description",
          "status",
          "resolution"
        ]
      }
    },
    "package_hash": {
      "type": "string",
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$"
    },
    "security_level": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "SENSITIVE",
        "CLASSIFIED"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "version",
    "claims",
    "conflicts",
    "package_hash",
    "security_level"
  ]
}
