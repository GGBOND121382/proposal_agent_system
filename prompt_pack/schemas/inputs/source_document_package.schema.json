{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_document_package.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "../common/document_context.schema.json"
      },
      "minItems": 1
    },
    "package_hash": {
      "type": "string",
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$"
    },
    "max_security_level": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "SENSITIVE",
        "CLASSIFIED"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "documents",
    "package_hash",
    "max_security_level"
  ]
}
