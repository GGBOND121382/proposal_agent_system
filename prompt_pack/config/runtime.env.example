# Runtime mode: MOCK, REPLAY, or LIVE
MODEL_RUNTIME_MODE=REPLAY
DENY_LIVE_CALLS_IN_CI=true

# Required offline endpoint
OFFLINE_LLM_ENABLED=true
OFFLINE_LLM_BASE_URL=http://offline-llm-gateway:8000/v1
OFFLINE_LLM_API_KEY=CHANGE_ME
OFFLINE_GENERAL_MODEL=CHANGE_ME
OFFLINE_CRITIC_MODEL=CHANGE_ME

# Optional online public endpoint, disabled by default
ONLINE_LLM_ENABLED=false
ONLINE_LLM_BASE_URL=
ONLINE_LLM_API_KEY=
ONLINE_PUBLIC_MODEL=

MODEL_REQUEST_TIMEOUT_SECONDS=240
