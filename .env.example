APP_HOST=0.0.0.0
APP_PORT=8080
APP_WORKERS=1
APP_RELOAD=false
APP_DATA_DIR=./data
PROMPT_PACK_DIR=./prompt_pack
MODEL_RUNTIME_MODE=REPLAY
DENY_LIVE_CALLS_IN_CI=true

# Track-A capability acceptance and durable model-call evidence.
# Formal capability runs must set MODEL_RUNTIME_MODE=LIVE and CAPABILITY_ACCEPTANCE_MODE=true.
CAPABILITY_ACCEPTANCE_MODE=false
MODEL_CALL_EVIDENCE_DIR=./data/model_calls
RUNTIME_EXPORT_EVIDENCE_DIR=./data/runtime_exports
MODEL_RESPONSE_AUTOMATION=false
SAMPLE_SECTION_FALLBACK=false
AUTO_RESPONSE_ENABLED=false
# Comma-separated one-shot points; leave empty outside fault-injection tests.
RUNTIME_FAULT_POINT=
RUNTIME_FAULT_ACTION=raise
RUNTIME_FAULT_CALL_KEY=
RUNTIME_FAULT_PROMPT_ID=
RUNTIME_FAULT_EXIT_CODE=97

OFFLINE_LLM_ENABLED=true
OFFLINE_LLM_BASE_URL=http://127.0.0.1:8000/v1
OFFLINE_LLM_API_KEY=CHANGE_ME
OFFLINE_GENERAL_MODEL=CHANGE_ME
OFFLINE_CRITIC_MODEL=CHANGE_ME

ONLINE_LLM_ENABLED=false
ONLINE_LLM_BASE_URL=
ONLINE_LLM_API_KEY=
ONLINE_PUBLIC_MODEL=

PUBLIC_SEARCH_PROVIDER=disabled
PUBLIC_SEARCH_BASE_URL=
# recorded: use a verified, archived public-source set without live network access.
# connector: archive raw responses returned by an approved search connector.
# searxng: run live search and archive every fetched source.
PUBLIC_RESEARCH_RECORD_FILE=
PUBLIC_RESEARCH_CONNECTOR_FILE=
PUBLIC_SEARCH_MAX_RESULTS=40
RESEARCH_FETCH_TIMEOUT_SECONDS=45
RESEARCH_MAX_SOURCE_BYTES=10485760

# Mermaid rendering. The JavaScript runtime is bundled in third_party/mermaid.
MERMAID_JS_PATH=./third_party/mermaid/mermaid.min.js
# Optional. Linux examples: /usr/bin/chromium; Windows usually auto-detects Edge.
MERMAID_BROWSER_EXECUTABLE=
SKILL_TIMEOUT_SECONDS=60
MODEL_REQUEST_TIMEOUT_SECONDS=240
MAX_UPLOAD_MB=50

# 强制结构化申请书质量门（生产环境必须保持true）
PROPOSAL_QUALITY_GUARD_ENABLED=true
