{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "actual_model_id",
    "endpoint_id",
    "batch_id",
    "verdict",
    "checked_section_ids",
    "quality_dimensions",
    "findings",
    "next_stage_decision",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "prompt_id": {
      "const": "P-STAGE6D-BATCH-CRITIC"
    },
    "prompt_version": {
      "const": "1.0.0"
    },
    "actual_model_id": {
      "type": "string",
      "minLength": 2
    },
    "endpoint_id": {
      "type": "string",
      "minLength": 2
    },
    "batch_id": {
      "const": "STAGE-6D"
    },
    "verdict": {
      "enum": [
        "ACCEPT",
        "REVISE"
      ]
    },
    "checked_section_ids": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "enum": [
          "SEC-12",
          "SEC-13",
          "SEC-14"
        ]
      },
      "uniqueItems": true
    },
    "quality_dimensions": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": [
          "dimension",
          "result",
          "comment"
        ],
        "additionalProperties": false,
        "properties": {
          "dimension": {
            "enum": [
              "PLAN_DEPENDENCY_AND_MILESTONES",
              "RISK_MONITORING_AND_DEGRADATION",
              "CONCLUSION_RQ_CLOSURE",
              "CENTRAL_PROPOSITION_BOUNDARY",
              "OPEN_ITEM_CALIBRATION",
              "CROSS_SECTION_NONREDUNDANCY",
              "PAGE_BUDGET"
            ]
          },
          "result": {
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "comment": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "next_stage_decision": {
      "enum": [
        "ALLOW_STAGE_7",
        "HOLD_STAGE_7"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 30
    }
  }
}
