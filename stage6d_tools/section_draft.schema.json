{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "actual_model_id",
    "endpoint_id",
    "status",
    "section_id",
    "candidate",
    "findings",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "prompt_id": {
      "const": "P-STAGE6D-WRITE-SECTION"
    },
    "prompt_version": {
      "const": "1.0.0"
    },
    "actual_model_id": {
      "type": "string",
      "minLength": 2
    },
    "endpoint_id": {
      "type": "string",
      "minLength": 2
    },
    "status": {
      "enum": [
        "PASS",
        "REVISE",
        "BLOCK"
      ]
    },
    "section_id": {
      "pattern": "^SEC-(12|13|14)$"
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "section_name",
        "markdown",
        "subsections",
        "visual_placeholders",
        "unresolved_open_item_ids",
        "key_terms",
        "section_contribution"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
        },
        "section_name": {
          "type": "string",
          "minLength": 2
        },
        "markdown": {
          "type": "string",
          "minLength": 120
        },
        "subsections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "subsection_id",
              "title",
              "paragraphs"
            ],
            "additionalProperties": false,
            "properties": {
              "subsection_id": {
                "pattern": "^SEC-(12|13|14)-[0-9]{2}$"
              },
              "title": {
                "type": "string",
                "minLength": 2
              },
              "paragraphs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "paragraph_id",
                    "role",
                    "text",
                    "node_ids",
                    "rq_ids",
                    "source_ids",
                    "claim_status",
                    "novel_content_key"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "paragraph_id": {
                      "type": "string",
                      "pattern": "^P-SEC-(12|13|14)-[0-9]{2}$"
                    },
                    "role": {
                      "type": "string",
                      "minLength": 4
                    },
                    "text": {
                      "type": "string",
                      "minLength": 30
                    },
                    "node_ids": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "uniqueItems": true
                    },
                    "rq_ids": {
                      "type": "array",
                      "items": {
                        "enum": [
                          "RQ-1",
                          "RQ-2",
                          "RQ-3"
                        ]
                      },
                      "uniqueItems": true
                    },
                    "source_ids": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "uniqueItems": true
                    },
                    "claim_status": {
                      "enum": [
                        "PUBLIC_RESEARCH_SUMMARY",
                        "CONFIRMED_DESIGN",
                        "PROJECT_PLAN",
                        "QUALIFIED_USER_ASSERTED",
                        "BOUNDARY_STATEMENT"
                      ]
                    },
                    "novel_content_key": {
                      "type": "string",
                      "minLength": 8
                    }
                  }
                }
              }
            }
          }
        },
        "visual_placeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "visual_id",
              "caption",
              "placement_after_paragraph_id"
            ],
            "additionalProperties": false,
            "properties": {
              "visual_id": {
                "pattern": "^(FIG|TAB)-[0-9]{2}$"
              },
              "caption": {
                "type": "string",
                "minLength": 4
              },
              "placement_after_paragraph_id": {
                "type": "string"
              }
            }
          }
        },
        "unresolved_open_item_ids": {
          "type": "array",
          "items": {
            "pattern": "^OPEN-[0-9]{3}$"
          },
          "uniqueItems": true
        },
        "key_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "term",
              "canonical_form"
            ],
            "additionalProperties": false,
            "properties": {
              "term": {
                "type": "string",
                "minLength": 2
              },
              "canonical_form": {
                "type": "string",
                "minLength": 2
              }
            }
          }
        },
        "section_contribution": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
