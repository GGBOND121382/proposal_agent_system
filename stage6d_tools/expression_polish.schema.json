{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "prompt_id",
    "prompt_version",
    "actual_model_id",
    "endpoint_id",
    "section_id",
    "status",
    "candidate",
    "change_log",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "prompt_id": {
      "const": "P-STAGE6D-EXPRESSION-POLISH"
    },
    "prompt_version": {
      "const": "1.0.0"
    },
    "actual_model_id": {
      "type": "string",
      "minLength": 2
    },
    "endpoint_id": {
      "type": "string",
      "minLength": 2
    },
    "section_id": {
      "pattern": "^SEC-(12|13|14)$"
    },
    "status": {
      "enum": [
        "PASS",
        "REVISE"
      ]
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "section_name",
        "markdown",
        "subsections",
        "visual_placeholders",
        "unresolved_open_item_ids",
        "key_terms",
        "section_contribution"
      ]
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "paragraph_id",
          "action",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "paragraph_id": {
            "type": "string"
          },
          "action": {
            "enum": [
              "PRESERVED",
              "POLISHED"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 4
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
