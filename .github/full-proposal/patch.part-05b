+def _source_commit() -> str:
+    value = os.getenv("GITHUB_SHA")
+    if value:
+        return value
+    completed = subprocess.run(
+        ["git", "rev-parse", "HEAD"], cwd=ROOT, text=True, capture_output=True, check=False
