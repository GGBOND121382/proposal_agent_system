+    SECTION_PHASES = {
+        "BLUEPRINT": ("P-WRITE-BLUEPRINT", "BLUEPRINT_CRITIC"),
+        "BLUEPRINT_CRITIC": ("P-WRITE-BLUEPRINT-CRITIC", "CONTENT"),
+        "CONTENT": ("P-WRITE-CONTENT", "CONTENT_CRITIC"),
