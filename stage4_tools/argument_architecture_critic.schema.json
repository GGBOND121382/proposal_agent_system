{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage4ArgumentArchitectureCritic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage",
    "verdict",
    "approved_candidate_hash",
    "checked_node_ids",
    "chain_checks",
    "quality_dimensions",
    "findings",
    "unresolved_gap_ids",
    "next_stage_decision",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "stage": {
      "const": "STAGE_4_ARGUMENT_ARCHITECTURE_CRITIC"
    },
    "verdict": {
      "enum": [
        "ACCEPT",
        "REVISE",
        "BLOCK"
      ]
    },
    "approved_candidate_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checked_node_ids": {
      "type": "array",
      "minItems": 30,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "chain_checks": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chain_type",
          "passed",
          "evidence",
          "affected_ids"
        ],
        "properties": {
          "chain_type": {
            "enum": [
              "GAP_TO_RQ",
              "RQ_TO_OBJECTIVE",
              "OBJECTIVE_TO_CONTENT",
              "CONTENT_TO_METHOD",
              "METHOD_TO_EXPERIMENT",
              "PRIOR_WORK_TO_INNOVATION",
              "FOUNDATION_TO_FEASIBILITY"
            ]
          },
          "passed": {
            "type": "boolean"
          },
          "evidence": {
            "type": "string",
            "minLength": 20
          },
          "affected_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            }
          }
        }
      }
    },
    "quality_dimensions": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dimension",
          "passed",
          "score",
          "evidence"
        ],
        "properties": {
          "dimension": {
            "enum": [
              "CENTRAL_THESIS",
              "ARGUMENT_CHAIN",
              "EVIDENCE_SUPPORT",
              "METHOD_SUBSTANCE",
              "INNOVATION_BASELINE",
              "FEASIBILITY_FOUNDATION",
              "METRIC_JUSTIFICATION"
            ]
          },
          "passed": {
            "type": "boolean"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "evidence": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "code",
          "message",
          "target_ids",
          "suggested_route"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^FIND-[0-9]{3}$"
          },
          "severity": {
            "enum": [
              "BLOCKING",
              "MAJOR",
              "MINOR",
              "INFO"
            ]
          },
          "code": {
            "type": "string",
            "minLength": 3
          },
          "message": {
            "type": "string",
            "minLength": 8
          },
          "target_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggested_route": {
            "enum": [
              "STAGE2_FACT_BASE",
              "STAGE3_PROJECT_DEFINITION",
              "STAGE4_ARGUMENT_ARCHITECTURE",
              "USER_INPUT_OR_RESEARCH",
              "NONE"
            ]
          }
        }
      }
    },
    "unresolved_gap_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^EVID-GAP-[0-9]{2}$"
      }
    },
    "next_stage_decision": {
      "enum": [
        "ALLOW_SECTION_PLANNING",
        "HOLD_SECTION_PLANNING"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 80
    }
  }
}
